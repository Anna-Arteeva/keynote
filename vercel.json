{
  "rewrites": [
    { "source": "/notes", "destination": "/notes.html" },
    { "source": "/notes/(.*)", "destination": "/notes.html" },
    { "source": "/talk", "destination": "/talk.html" },
    { "source": "/((?!assets|favicon|apple-touch|site\\.webmanifest|notes|talk).*)", "destination": "/index.html" }
  ]
}
